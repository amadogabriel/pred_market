# pm-system environment. Copy to .env and fill in. NEVER commit the real .env.
# Loaded by systemd via EnvironmentFile=; for local dev, `source` it or export.

# --- paths ---
PM_DB_PATH=/home/pm/pm-system/data/state.db
PM_EVENTS_DIR=/home/pm/pm-system/data/events
PM_HEARTBEAT=/home/pm/pm-system/data/heartbeat
PM_FEES_YAML=/home/pm/pm-system/config/fees.yaml

# --- telegram (monitor alerts; leave token empty to print instead) ---
PM_TG_TOKEN=your-bot-token-here
PM_TG_CHAT=your-chat-id-here

# --- market universe ---
PM_TRACK_TOP_N=150
PM_MIN_LIQUIDITY=1000
PM_WS_CHUNK=100

# --- cadence (seconds) ---
PM_META_INTERVAL=3600
PM_RECON_INTERVAL=300
PM_HB_INTERVAL=15
PM_HB_STALE=120
PM_SCAN_INTERVAL=1.0
PM_STALE_BOOK=30

# --- struct arb ---
PM_ARB_BUFFER=0.01
PM_ARB_MIN_SETS=10

# --- research signals (S2 microstructure / S3 relative value; never executable) ---
PM_RESEARCH_SIGNALS=true
PM_MICRO_WINDOW=300
PM_MICRO_MIN_SAMPLES=20
PM_MICRO_OFI=0.6
PM_MICRO_MAX_SPREAD=0.03
PM_MICRO_LIQ_SPREAD_MULT=3.0
PM_MICRO_LIQ_DEPTH_DROP=0.5
PM_MICRO_TRADE_FLOOR=0.01
PM_MICRO_DEBOUNCE=120
PM_RV_WINDOW=1800
PM_RV_MIN_SAMPLES=30
PM_RV_Z=3.0
PM_RV_MIN_DEV=0.02
PM_RV_DEBOUNCE=120

# --- momentum / boundary-overshoot (S4 research; never executable) ---
PM_MOM_WINDOW=300
PM_MOM_MIN_SAMPLES=20
PM_MOM_Z=2.5
PM_MOM_MIN_DRIFT=0.01
PM_MOM_BND_LOW=0.05
PM_MOM_BND_HIGH=0.95
PM_MOM_BND_BOUNCE=0.01
PM_MOM_DEBOUNCE=180

# --- signal outcome labeler (fills signal_log.outcome with forward returns) ---
PM_LABEL_HORIZON=900
PM_LABEL_MAX_AGE=86400
PM_LABEL_BATCH=200
PM_LABEL_POLL=60

# --- execution / risk gates (Phase 1+, default closed) ---
# Strategy allowlist: ONLY these strategies can ever form execution plans.
# Research strategies (microstructure, rel_value) must never be added here
# until they have been validated against labeler outcomes and reviewed.
PM_EXECUTION_STRATEGIES=struct_arb
PM_EXECUTION_ENABLED=false
PM_EXECUTION_MODE=dry_run
PM_LIVE_TRADING=false
PM_MAX_ORDER_NOTIONAL=25
PM_MAX_SIGNAL_NOTIONAL=100
PM_MAX_OPEN_NOTIONAL=250
PM_MAX_DAILY_LOSS=50
PM_MAX_RECON_DIFF_EXEC=0.01
PM_ALLOW_UNVERIFIED_NEGRISK=false
PM_VERIFIED_GROUPS=/home/pm/pm-system/config/verified_negrisk_groups.txt
PM_KILL_SWITCH=/home/pm/pm-system/data/KILL_SWITCH

# --- whale-follow (S5, on-chain Polygon, research only) ---
# Empty PM_POLYGON_RPC_URL = ctf_listener disabled (engine still runs).
# A keyless public node works, e.g. https://polygon.drpc.org
# (polygon-rpc.com and ankr now require an API key).
PM_POLYGON_RPC_URL=
PM_POLYGON_CTF_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
PM_POLYGON_POLL_S=12
PM_POLYGON_LOOKBACK_BLOCKS=8
# The CTF contract is very active (~85 transfers/block); keep getLogs windows
# small so public nodes don't time out on the response.
PM_POLYGON_MAX_BLOCK_SPAN=8
PM_WHALE_MIN_CALIB=0.55
PM_WHALE_MIN_RESOLVED=5
PM_WHALE_MIN_VALUE_RAW=100000000
PM_WHALE_DEBOUNCE=60
# discovery: record large positions from ANY wallet to build a candidate pool,
# then the scorer auto-promotes wallets whose resolved bets clear the bar.
PM_WHALE_DISCOVERY=true
PM_WHALE_DISCOVERY_VALUE_RAW=500000000
PM_WHALE_SCORE_POLL=600
PM_WHALE_PROMOTE_CALIB=0.60
PM_WHALE_PROMOTE_MIN_RESOLVED=8

# --- news (S6, RSS, research only) ---
# Empty news_feeds.yaml file = poller idles; engine unaffected
PM_NEWS_FEEDS_YAML=/home/pm/pm-system/config/news_feeds.yaml
PM_NEWS_MIN_OVERLAP=2
PM_NEWS_TOP_K=3
PM_NEWS_DEBOUNCE=300
PM_NEWS_INDEX_REFRESH=300

# --- calibration model (S7, periodic divergence, research only) ---
PM_BASE_RATES_YAML=/home/pm/pm-system/config/base_rates.yaml
PM_CALIB_EDGE=0.10
PM_CALIB_MIN_TTM=86400
PM_CALIB_POLL=600
PM_CALIB_DEBOUNCE=3600
# Metaculus locked its public API behind auth in 2025/26 — leaving this true
# without a token just yields 403s and no external prob. Calibration then runs
# on config/base_rates.yaml alone, which ships as placeholders (n_samples=0).
# Curate real, sourced base rates before expecting calibration to emit.
PM_CALIB_METACULUS=false

# --- Kelly sizing (applied only when an executable signal is allowlisted) ---
PM_KELLY_FACTOR=0.5
PM_KELLY_PER_TRADE_CAP=25
PM_KELLY_TTM_CLIFF=259200
PM_KELLY_TTM_FLOOR=0.25

# --- local AI meta-label model (research triage; never submits orders) ---
PM_AI_MODEL_PATH=/home/pm/pm-system/data/ai_model.json
PM_AI_MIN_SAMPLES=50
PM_AI_TRAIN_INTERVAL=900

# --- paper trading (simulated money; never touches the real execution path) ---
PM_PAPER_ENABLED=true
PM_PAPER_BANKROLL=100
PM_PAPER_PER_TRADE=10
PM_PAPER_HOLD_S=1800
PM_PAPER_POLL_S=20
# Which strategies the paper account trades. It fills at the touch (buy at the
# ask, sell at the bid) and pays the real fee, so the P&L is honest. Note the
# high-frequency dead-end signals (microstructure) will dominate turnover
# unless you narrow this list, e.g. to: struct_arb,whale_follow,news
PM_PAPER_STRATEGIES=struct_arb,whale_follow,news,microstructure,rel_value,momentum

# --- dashboard (read-only web UI) ---
PM_DASH_HOST=127.0.0.1
PM_DASH_PORT=8787
