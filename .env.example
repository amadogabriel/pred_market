# pm-system environment. Copy to .env and fill in. NEVER commit the real .env.
# Loaded by systemd via EnvironmentFile=; for local dev, `source` it or export.

# --- paths ---
PM_DB_PATH=/home/pm/pm-system/data/state.db
PM_EVENTS_DIR=/home/pm/pm-system/data/events
PM_HEARTBEAT=/home/pm/pm-system/data/heartbeat
PM_FEES_YAML=/home/pm/pm-system/config/fees.yaml

# --- telegram (monitor alerts; leave token empty to print instead) ---
PM_TG_TOKEN=your-bot-token-here
PM_TG_CHAT=your-chat-id-here

# --- market universe ---
PM_TRACK_TOP_N=150
PM_MIN_LIQUIDITY=1000
PM_WS_CHUNK=100

# --- cadence (seconds) ---
PM_META_INTERVAL=3600
PM_RECON_INTERVAL=300
PM_HB_INTERVAL=15
PM_HB_STALE=120
PM_SCAN_INTERVAL=1.0
PM_STALE_BOOK=30

# --- struct arb ---
PM_ARB_BUFFER=0.01
PM_ARB_MIN_SETS=10

# --- research signals (S2 microstructure / S3 relative value; never executable) ---
PM_RESEARCH_SIGNALS=true
PM_MICRO_WINDOW=300
PM_MICRO_MIN_SAMPLES=20
PM_MICRO_OFI=0.6
PM_MICRO_MAX_SPREAD=0.03
PM_MICRO_LIQ_SPREAD_MULT=3.0
PM_MICRO_LIQ_DEPTH_DROP=0.5
PM_MICRO_TRADE_FLOOR=0.01
PM_MICRO_DEBOUNCE=120
PM_RV_WINDOW=1800
PM_RV_MIN_SAMPLES=30
PM_RV_Z=3.0
PM_RV_MIN_DEV=0.02
PM_RV_DEBOUNCE=120

# --- signal outcome labeler (fills signal_log.outcome with forward returns) ---
PM_LABEL_HORIZON=900
PM_LABEL_MAX_AGE=86400
PM_LABEL_BATCH=200
PM_LABEL_POLL=60

# --- execution / risk gates (Phase 1+, default closed) ---
# Strategy allowlist: ONLY these strategies can ever form execution plans.
# Research strategies (microstructure, rel_value) must never be added here
# until they have been validated against labeler outcomes and reviewed.
PM_EXECUTION_STRATEGIES=struct_arb
PM_EXECUTION_ENABLED=false
PM_EXECUTION_MODE=dry_run
PM_LIVE_TRADING=false
PM_MAX_ORDER_NOTIONAL=25
PM_MAX_SIGNAL_NOTIONAL=100
PM_MAX_OPEN_NOTIONAL=250
PM_MAX_DAILY_LOSS=50
PM_MAX_RECON_DIFF_EXEC=0.01
PM_ALLOW_UNVERIFIED_NEGRISK=false
PM_VERIFIED_GROUPS=/home/pm/pm-system/config/verified_negrisk_groups.txt
PM_KILL_SWITCH=/home/pm/pm-system/data/KILL_SWITCH

# --- dashboard (read-only web UI) ---
PM_DASH_HOST=127.0.0.1
PM_DASH_PORT=8787
